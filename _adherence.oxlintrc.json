{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/forms/**",
              "components/icons/**",
              "components/navigation/**",
              "ui_kits/pantherloop_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|src|size|tier|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, src, size, tier."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:none|helper|driver)$/]",
        "message": "<Avatar> tier must be one of 'none' | 'helper' | 'driver'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|icon|label|fab|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: key, icon, label, fab."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accept|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accept' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|key|ref|className|style|children)$/]",
        "message": "<CategoryPill> doesn't accept that prop. Declared props: active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|iconLeft|prefix|multiline|rows|disabled|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, iconLeft, prefix, multiline, rows, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|status|location|category|deadline|description|posterName|posterInitials|posterTier|rating|price|key|ref|className|style|children)$/]",
        "message": "<TaskCard> doesn't accept that prop. Declared props: title, status, location, category, deadline, description, posterName, posterInitials, posterTier, rating, price."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskCard'] > JSXAttribute[name.name='posterTier'] > Literal[value!=/^(?:none|helper|driver)$/]",
        "message": "<TaskCard> posterTier must be one of 'none' | 'helper' | 'driver'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopAppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|align|onBack|right|rightInitials|badge|onRight|key|ref|className|style|children)$/]",
        "message": "<TopAppBar> doesn't accept that prop. Declared props: title, align, onBack, right, rightInitials, badge, onRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopAppBar'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<TopAppBar> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopAppBar'] > JSXAttribute[name.name='right'] > Literal[value!=/^(?:none|bell|avatar)$/]",
        "message": "<TopAppBar> right must be one of 'none' | 'bell' | 'avatar'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
